{
  "name": "surelyai-monorepo",
  "private": true,
  "workspaces": ["apps/frontend", "apps/backend"],
  "scripts": {
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:backend": "cd apps/backend && uvicorn main:app --reload --port 8000",
    "install:all": "cd apps/frontend && npm install"
  }
}
